# Базовый URL API (обязательно для Vite: префикс VITE_).
#
# Локальная разработка (бэкенд на другом сервере):
#   VITE_API_BASE_URL=http://185.239.50.252:8080
#
# Продакшен на том же сервере (Nginx проксирует /api на бэкенд):
#   VITE_API_BASE_URL=/api
#
# Один сервер без префикса /api:
#   не задавать или VITE_API_BASE_URL=
