# Базовый URL API (обязательно для Vite: префикс VITE_).
#
# --- Фронт и бэкенд на одном сервере, каждый в своём Docker ---
# Сборка и запуск фронта: docker compose build cars-prod && docker compose up -d cars-prod
#   VITE_API_BASE_URL=/api
#   BACKEND_HOST=IP_СЕРВЕРА:8080
# Пример (бэкенд слушает на 8080 на хосте):
#   VITE_API_BASE_URL=/api
#   BACKEND_HOST=185.239.50.252:8080
#
# --- Локальная разработка (бэкенд на другом сервере) ---
#   VITE_API_BASE_URL=http://185.239.50.252:8080
#   (BACKEND_HOST при запуске фронта в Docker не нужен)
#
# Если бэкенд отдаёт роуты без префикса /api (только /brands), в nginx.conf замените
# proxy_pass http://${BACKEND_HOST}/api/ на proxy_pass http://${BACKEND_HOST}/;
